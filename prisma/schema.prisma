generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  user
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String?
  name               String?
  image              String?
  role               UserRole            @default(user)
  emailVerified      DateTime?
  resetOTP           String?
  resetOTPExpires    DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  articles           Article[]
  comments           Comment[]
  accounts           Account[]
  sessions           Session[]
  articleClicks      ArticleClick[]
  articleEngagements ArticleEngagement[]
  sessionRecordings  SessionRecording[]
  userSessions       UserSession[]
  heatmapEvents      HeatmapEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
}

model Article {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  content    String
  excerpt    String?
  image      String?
  featured   Boolean   @default(false)
  published  Boolean   @default(false)
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  comments   Comment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  articleId String
  article   Article  @relation(fields: [articleId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model NewsSource {
  id        String   @id @default(cuid())
  country   String
  name      String
  category  String
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([country, name, category])
}

model Analytics {
  id        String   @id @default(cuid())
  path      String   @unique
  views     Int      @default(0)
  avgTime   Float    @default(0)
  totalTime Float    @default(0)
  sessions  Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ArticleClick {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  articleId String
  category  String
  title     String   @default("")
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

model ArticleEngagement {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  articleId         String
  category          String
  timeSpentSeconds  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, articleId])
  @@index([articleId])
  @@index([category])
}

model SessionRecording {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  cloudinaryUrl   String
  durationSeconds Int
  createdAt       DateTime @default(now())

  @@index([userId])
}

model UserSession {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime       @default(now())
  endedAt       DateTime?
  totalDuration Int?
  aiReport      String?        @db.Text
  reportedAt    DateTime?
  heatmapEvents HeatmapEvent[]

  @@index([userId])
}

model HeatmapEvent {
  id          String       @id @default(cuid())
  type        String
  page        String
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     UserSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  x           Float?
  y           Float?
  scrollDepth Int?
  viewport    String       @db.Text
  timestamp   DateTime

  @@index([page, type])
  @@index([userId])
  @@index([timestamp])
}
